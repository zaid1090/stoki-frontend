const express = require('express');
const cors = require('cors');
const app = express();

app.use(cors());
app.use(express.json());

// مسار فحص صحة المحرك
app.get('/', (req, res) => {
    res.send('FOMO Engine Backend is Running!');
});

// مسار استقبال طلبات الشراء العاجلة (FOMO)
app.post('/api/checkout', (req, res) => {
    const { productId, action, timestamp } = req.body;
    
    console.log(`[New Order] Product: ${productId} | Action: ${action} | Time: ${timestamp}`);
    
    // محاكاة الاستجابة وتأكيد حجز المنتج العاجل
    res.status(200).json({
        status: 'success',
        message: 'تم تأكيد الطلب واقتناص العرض بنجاح!',
        productId: productId,
        stockRemaining: 1 
    });
});

const PORT = process.env.PORT || 8080;
app.listen(PORT, () => {
    console.log(`FOMO Backend Engine running on port ${PORT}`);
});
